{
  "name": "@aviato-media/official-plugins",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "description": "Official plugins for Aviato.",
  "repository": {
    "type": "git",
    "url": "https://github.com/aviato-media/official-plugins"
  },
  "workspaces": {
    "packages": [
      "plugins/*"
    ],
    "catalog": {
      "@aviato-media/plugin-sdk": "^1.1.1"
    }
  },
  "scripts": {
    "build": "bun run scripts/build-plugin.ts",
    "pack": "bun run scripts/pack-plugin.ts",
    "release": "bun run scripts/release-plugin.ts",
    "changed": "bun run scripts/changed-plugins.ts",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun test",
    "lint": "eslint 'plugins/*/src/**/*.ts' 'scripts/**/*.ts'",
    "lint:fix": "eslint --fix 'plugins/*/src/**/*.ts' 'scripts/**/*.ts'",
    "prepare": "husky"
  },
  "packageManager": "bun@1.3.13",
  "devDependencies": {
    "@benhutchins/eslint-joy": "1.0.1",
    "@types/bun": "^1.3.13",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aviato-media/plugin-sdk": "catalog:"
  }
}
